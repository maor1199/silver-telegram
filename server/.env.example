# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Supabase (required for DB and optional report saving)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Google OAuth: configure these in Supabase Dashboard (Auth → Providers → Google),
# not here. Kept as reference if you need them elsewhere.
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# AI Listing Builder – Premium copy (Claude)
ANTHROPIC_API_KEY=sk-ant-...
# Optional: ANTHROPIC_LISTING_MODEL=claude-sonnet-4-20250514

# Image-to-image (Replicate Flux) – required for product photo → listing images
REPLICATE_API_TOKEN=r8_...
# Optional: REPLICATE_FLUX_MODEL=bxclib2/flux_img2img

# OpenAI (fallback copy + image-prompt generation)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_LISTING_MODEL=gpt-4o
OPENAI_DALLE_ENABLED=false
# OPENAI_DALLE_QUALITY=hd

# Hero image: Remove.bg (type=product, semitransparency=false, roi=full) then white #FFFFFF.
# Put key ONLY in server/.env (never in code or client). Get key: https://www.remove.bg/api
# REMOVE_BG_API_KEY=your_key_here

# Supabase Storage for product photo uploads (create public bucket "listing-uploads")
# SUPABASE_LISTING_BUCKET=listing-uploads

# Rainforest (market data)
RAINFOREST_DOMAIN=amazon.com
RAINFOREST_API_KEY=...
