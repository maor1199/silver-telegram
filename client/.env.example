# Supabase (required for login, signup, and auth-protected pages)
# Get these from your project: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: redirect URL after email confirmation (signup)
# NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/analyze

# Analyze (runs in Vercel Serverless /api/analyze): AI insights + optional live market data
# OPENAI_API_KEY              (required for Analyze) — OpenAI API key for AI insights
# OPENAI_MODEL                (optional) — e.g. gpt-4o-mini (default)
# RAINFOREST_API_KEY          (optional) — Rainforest API for live Amazon market data; omit for stub data
# RAINFOREST_DOMAIN           (optional) — amazon.com for US, amazon.co.uk, etc.
# Example (uncomment and set):
# RAINFOREST_API_KEY=your-rainforest-api-key
# RAINFOREST_DOMAIN=amazon.com

# ═══════════════════════════════════════════════════════════════════
# VERCEL (production) — set in Vercel → Project → Settings → Environment Variables
# ═══════════════════════════════════════════════════════════════════
# NEXT_PUBLIC_SUPABASE_URL     (required) — Supabase project URL
# NEXT_PUBLIC_SUPABASE_ANON_KEY (required) — Supabase anon key
# OPENAI_API_KEY              (required for Analyze)
# RAINFOREST_API_KEY          (optional) — live market data
# ═══════════════════════════════════════════════════════════════════
