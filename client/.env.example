# Supabase (required for login, signup, and auth-protected pages)
# Get these from your project: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: redirect URL after email confirmation (signup)
# NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=http://localhost:3000/analyze

# Analyze API: backend URL (default: http://localhost:3001). Use ngrok URL if client and server run on different hosts.
# ANALYZE_BACKEND_URL=https://your-ngrok-subdomain.ngrok-free.dev
